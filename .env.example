# Google OAuth credentials
# Get these from console.cloud.google.com
# 1. Create a project, enable Google Calendar API
# 2. Create OAuth 2.0 credentials (Web Application type)
# 3. Add http://localhost:3000/auth/callback as an authorized redirect URI
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Server port (must match the redirect URI port registered in Google Cloud Console)
PORT=3000
